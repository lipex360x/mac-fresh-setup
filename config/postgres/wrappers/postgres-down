#!/usr/bin/env python3
"""postgres-down: stop the standalone PostgreSQL daemon."""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
import time
from pathlib import Path

IS_WIN = sys.platform == "win32"

ROOT = Path.home() / ".local" / "share" / "mac-fresh-setup" / "postgres"
CONFIG = ROOT / "config.json"
DATA = ROOT / "data"


def _load_config() -> dict:
    if not CONFIG.exists():
        sys.exit(
            "PostgreSQL is not installed. "
            "Run mac-fresh-setup → Databases → PostgreSQL → Install."
        )
    return json.loads(CONFIG.read_text())


def _bin(cfg: dict, name: str) -> Path:
    exe = f"{name}.exe" if IS_WIN else name
    return Path(cfg["install_dir"]) / "bin" / exe


def _pid_alive(pid: int) -> bool:
    if IS_WIN:
        result = subprocess.run(
            ["tasklist", "/FI", f"PID eq {pid}", "/NH", "/FO", "CSV"],
            capture_output=True,
            text=True,
        )
        return result.returncode == 0 and str(pid) in result.stdout
    try:
        os.kill(pid, 0)
        return True
    except (ProcessLookupError, PermissionError):
        return False


def _running() -> bool:
    pid_file = DATA / "postmaster.pid"
    if not pid_file.exists():
        return False
    try:
        first_line = pid_file.read_text().splitlines()[0].strip()
        pid = int(first_line)
    except (OSError, ValueError, IndexError):
        return False
    return _pid_alive(pid)


def main() -> None:
    argparse.ArgumentParser(
        prog="postgres-down",
        description="Stop the standalone PostgreSQL daemon (mac-fresh-setup).",
    ).parse_args()

    cfg = _load_config()
    if not _running():
        print("PostgreSQL is not running.")
        return

    pg_ctl_cmd = [
        str(_bin(cfg, "pg_ctl")),
        "-D", str(DATA),
        "-m", "fast",
        "stop",
    ]
    if IS_WIN:
        startupinfo = subprocess.STARTUPINFO()
        startupinfo.dwFlags |= subprocess.STARTF_USESHOWWINDOW
        startupinfo.wShowWindow = 0
        rc = subprocess.run(
            pg_ctl_cmd,
            startupinfo=startupinfo,
            creationflags=subprocess.CREATE_NO_WINDOW,
        ).returncode
    else:
        rc = subprocess.run(pg_ctl_cmd).returncode
    if rc != 0:
        sys.exit(f"pg_ctl stop failed (rc={rc}).")

    for _ in range(30):
        if not _running():
            break
        time.sleep(0.5)
    else:
        sys.exit("PostgreSQL did not stop within 15s.")

    print("PostgreSQL stopped.")


if __name__ == "__main__":
    main()
