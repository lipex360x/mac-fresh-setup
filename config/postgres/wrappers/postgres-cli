#!/usr/bin/env python3
"""postgres-cli: open psql connected to the standalone PostgreSQL instance."""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
from pathlib import Path

IS_WIN = sys.platform == "win32"

ROOT = Path.home() / ".local" / "share" / "mac-fresh-setup" / "postgres"
CONFIG = ROOT / "config.json"
DATA = ROOT / "data"


def _load_config() -> dict:
    if not CONFIG.exists():
        sys.exit(
            "PostgreSQL is not installed. "
            "Run mac-fresh-setup → Databases → PostgreSQL → Install."
        )
    return json.loads(CONFIG.read_text())


def _bin(cfg: dict, name: str) -> Path:
    exe = f"{name}.exe" if IS_WIN else name
    return Path(cfg["install_dir"]) / "bin" / exe


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="postgres-cli",
        description=(
            "Open psql connected to the standalone PostgreSQL instance. "
            "Extra arguments are forwarded to psql (after a `--` separator "
            "if they collide with the wrapper, e.g. `postgres-cli -- -h other_host`)."
        ),
        add_help=False,
    )
    parser.add_argument(
        "--help", action="help", help="show this help message and exit",
    )
    parser.add_argument(
        "-p", "--port", type=int,
        help="Override the port from config.json (handy for debug sessions).",
    )
    parser.add_argument(
        "extra", nargs=argparse.REMAINDER,
        help="Extra args passed to psql (e.g. -c 'SELECT 1', a database name).",
    )
    args = parser.parse_args()

    cfg = _load_config()
    port = args.port or cfg["port"]

    env = os.environ.copy()
    if cfg.get("password"):
        env["PGPASSWORD"] = cfg["password"]

    cmd = [
        str(_bin(cfg, "psql")),
        "-h", "127.0.0.1",
        "-p", str(port),
        "-U", "postgres",
    ]
    cmd.extend(args.extra)

    if IS_WIN:
        sys.exit(subprocess.run(cmd, env=env).returncode)
    os.execvpe(cmd[0], cmd, env)


if __name__ == "__main__":
    main()
