#!/usr/bin/env python3
"""mysql-cli: open the standalone MySQL client connected via the local socket (TCP on Windows)."""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
from pathlib import Path

IS_WIN = sys.platform == "win32"

ROOT = Path.home() / ".local" / "share" / "mac-fresh-setup" / "mysql"
CONFIG = ROOT / "config.json"
RUNTIME = ROOT / "runtime"
PID = RUNTIME / "mysql.pid"
SOCK = RUNTIME / "mysql.sock"


def _load_config() -> dict:
    if not CONFIG.exists():
        sys.exit(
            "MySQL is not installed. Run mac-fresh-setup → Databases → MySQL → Install."
        )
    return json.loads(CONFIG.read_text())


def _pid_alive(pid: int) -> bool:
    if IS_WIN:
        result = subprocess.run(
            ["tasklist", "/FI", f"PID eq {pid}", "/NH", "/FO", "CSV"],
            capture_output=True,
            text=True,
        )
        return result.returncode == 0 and str(pid) in result.stdout
    try:
        os.kill(pid, 0)
        return True
    except (ProcessLookupError, PermissionError):
        return False


def _running() -> bool:
    if not PID.exists():
        return False
    try:
        pid = int(PID.read_text().strip())
    except ValueError:
        return False
    return _pid_alive(pid)


def _bin(cfg: dict, name: str) -> Path:
    exe = f"{name}.exe" if IS_WIN else name
    return Path(cfg["install_dir"]) / "bin" / exe


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="mysql-cli",
        description=(
            "Open the standalone MySQL client. Connects via socket on Unix, "
            "TCP on Windows. Extra arguments are forwarded to the mysql binary."
        ),
    )
    parser.add_argument(
        "extra", nargs=argparse.REMAINDER,
        help="Extra args passed to mysql (e.g. -e 'SELECT 1', a database name).",
    )
    args = parser.parse_args()

    cfg = _load_config()
    if not _running():
        sys.exit("MySQL is not running. Start it with: mysql-up")

    cmd = [str(_bin(cfg, "mysql")), "-uroot"]
    if IS_WIN:
        cmd.extend(["-h127.0.0.1", f"-P{cfg['port']}"])
    else:
        cmd.append(f"--socket={SOCK}")
    if cfg.get("password"):
        cmd.append(f"-p{cfg['password']}")
    cmd.extend(args.extra)

    if IS_WIN:
        sys.exit(subprocess.run(cmd).returncode)
    os.execvp(cmd[0], cmd)


if __name__ == "__main__":
    main()
