#!/usr/bin/env python3
"""mysql-down: stop the standalone MySQL daemon."""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
import time
from pathlib import Path

ROOT = Path.home() / ".local" / "share" / "mac-fresh-setup" / "mysql"
CONFIG = ROOT / "config.json"
RUNTIME = ROOT / "runtime"
PID = RUNTIME / "mysql.pid"
SOCK = RUNTIME / "mysql.sock"


def _load_config() -> dict:
    if not CONFIG.exists():
        sys.exit(
            "MySQL is not installed. Run mac-fresh-setup → Databases → MySQL → Install."
        )
    return json.loads(CONFIG.read_text())


def _running() -> bool:
    if not PID.exists():
        return False
    try:
        pid = int(PID.read_text().strip())
        os.kill(pid, 0)
        return True
    except (ValueError, ProcessLookupError, PermissionError):
        return False


def _bin(cfg: dict, name: str) -> Path:
    return Path(cfg["install_dir"]) / "bin" / name


def main() -> None:
    argparse.ArgumentParser(
        prog="mysql-down",
        description="Stop the standalone MySQL daemon (mac-fresh-setup).",
    ).parse_args()

    cfg = _load_config()

    if not _running():
        print("MySQL is not running.")
        return

    cmd = [str(_bin(cfg, "mysqladmin")), "-uroot", f"--socket={SOCK}"]
    if cfg.get("password"):
        cmd.append(f"-p{cfg['password']}")
    cmd.append("shutdown")
    result = subprocess.run(cmd, capture_output=True, text=True)

    if result.returncode != 0:
        print(f"mysqladmin shutdown failed: {result.stderr.strip()}")
        print("Falling back to SIGTERM on the PID...")
        try:
            pid = int(PID.read_text().strip())
            os.kill(pid, 15)
        except (ValueError, ProcessLookupError):
            pass

    for _ in range(30):
        if not _running():
            break
        time.sleep(0.5)
    else:
        sys.exit("MySQL did not stop within 15s.")

    PID.unlink(missing_ok=True)
    print("MySQL stopped.")


if __name__ == "__main__":
    main()
