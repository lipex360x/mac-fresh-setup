#!/usr/bin/env python3
"""mysql-down: stop the standalone MySQL daemon."""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
import time
from pathlib import Path

IS_WIN = sys.platform == "win32"

ROOT = Path.home() / ".local" / "share" / "mac-fresh-setup" / "mysql"
CONFIG = ROOT / "config.json"
RUNTIME = ROOT / "runtime"
PID = RUNTIME / "mysql.pid"
SOCK = RUNTIME / "mysql.sock"


def _load_config() -> dict:
    if not CONFIG.exists():
        sys.exit(
            "MySQL is not installed. Run mac-fresh-setup → Databases → MySQL → Install."
        )
    return json.loads(CONFIG.read_text())


def _pid_alive(pid: int) -> bool:
    if IS_WIN:
        result = subprocess.run(
            ["tasklist", "/FI", f"PID eq {pid}", "/NH", "/FO", "CSV"],
            capture_output=True,
            text=True,
        )
        return result.returncode == 0 and str(pid) in result.stdout
    try:
        os.kill(pid, 0)
        return True
    except (ProcessLookupError, PermissionError):
        return False


def _running() -> bool:
    if not PID.exists():
        return False
    try:
        pid = int(PID.read_text().strip())
    except ValueError:
        return False
    return _pid_alive(pid)


def _bin(cfg: dict, name: str) -> Path:
    exe = f"{name}.exe" if IS_WIN else name
    return Path(cfg["install_dir"]) / "bin" / exe


def _kill(pid: int) -> None:
    if IS_WIN:
        subprocess.run(["taskkill", "/PID", str(pid), "/T"], capture_output=True)
        return
    try:
        os.kill(pid, 15)
    except (ProcessLookupError, PermissionError):
        pass


def main() -> None:
    argparse.ArgumentParser(
        prog="mysql-down",
        description="Stop the standalone MySQL daemon (mac-fresh-setup).",
    ).parse_args()

    cfg = _load_config()

    if not _running():
        print("MySQL is not running.")
        return

    cmd = [str(_bin(cfg, "mysqladmin")), "-uroot"]
    if IS_WIN:
        cmd.extend(["-h127.0.0.1", f"-P{cfg['port']}"])
    else:
        cmd.append(f"--socket={SOCK}")
    if cfg.get("password"):
        cmd.append(f"-p{cfg['password']}")
    cmd.append("shutdown")
    result = subprocess.run(cmd, capture_output=True, text=True)

    if result.returncode != 0:
        print(f"mysqladmin shutdown failed: {result.stderr.strip()}")
        print("Falling back to terminating the PID...")
        try:
            pid = int(PID.read_text().strip())
            _kill(pid)
        except (ValueError, FileNotFoundError):
            pass

    for _ in range(30):
        if not _running():
            break
        time.sleep(0.5)
    else:
        sys.exit("MySQL did not stop within 15s.")

    PID.unlink(missing_ok=True)
    print("MySQL stopped.")


if __name__ == "__main__":
    main()
