#!/usr/bin/env python3
"""mysql-up: start the standalone MySQL daemon."""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
import time
from pathlib import Path

ROOT = Path.home() / ".local" / "share" / "mac-fresh-setup" / "mysql"
CONFIG = ROOT / "config.json"
DATA = ROOT / "data"
RUNTIME = ROOT / "runtime"
PID = RUNTIME / "mysql.pid"
SOCK = RUNTIME / "mysql.sock"
LOG = RUNTIME / "mysql.log"


def _load_config() -> dict:
    if not CONFIG.exists():
        sys.exit(
            "MySQL is not installed. Run mac-fresh-setup → Databases → MySQL → Install."
        )
    return json.loads(CONFIG.read_text())


def _save_config(cfg: dict) -> None:
    CONFIG.write_text(json.dumps(cfg, indent=2))
    CONFIG.chmod(0o600)


def _running() -> bool:
    if not PID.exists():
        return False
    try:
        pid = int(PID.read_text().strip())
        os.kill(pid, 0)
        return True
    except (ValueError, ProcessLookupError, PermissionError):
        return False


def _bin(cfg: dict, name: str) -> Path:
    return Path(cfg["install_dir"]) / "bin" / name


def _initialize_data(cfg: dict) -> int:
    print(f"Initializing data dir at {DATA}...")
    DATA.mkdir(parents=True, exist_ok=True)
    result = subprocess.run([
        str(_bin(cfg, "mysqld")),
        "--initialize-insecure",
        f"--basedir={cfg['install_dir']}",
        f"--datadir={DATA}",
        f"--user={os.environ.get('USER', 'mysql')}",
    ])
    return result.returncode


def _start_daemon(cfg: dict) -> None:
    RUNTIME.mkdir(parents=True, exist_ok=True)
    cmd = [
        str(_bin(cfg, "mysqld_safe")),
        f"--basedir={cfg['install_dir']}",
        f"--datadir={DATA}",
        f"--user={os.environ.get('USER', 'mysql')}",
        f"--socket={SOCK}",
        f"--pid-file={PID}",
        f"--port={cfg['port']}",
    ]
    with LOG.open("a") as log:
        subprocess.Popen(
            cmd,
            stdout=log,
            stderr=subprocess.STDOUT,
            start_new_session=True,
        )


def _set_root_password(cfg: dict, new_pass: str) -> bool:
    old_pass = cfg.get("password", "") or ""
    cmd = [str(_bin(cfg, "mysqladmin")), "-uroot", f"--socket={SOCK}"]
    if old_pass:
        cmd.append(f"-p{old_pass}")
    cmd.extend(["password", new_pass])
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        print(f"Could not set root password: {result.stderr.strip()}")
        return False
    return True


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="mysql-up",
        description="Start the standalone MySQL daemon (mac-fresh-setup).",
    )
    parser.add_argument(
        "-p", "--port", type=int,
        help="Port to listen on. Saved to config; reused by next mysql-up.",
    )
    parser.add_argument(
        "--pass", dest="password",
        help="Set/change the root password. Saved to config so mysql-cli works.",
    )
    args = parser.parse_args()

    cfg = _load_config()
    config_changed = False
    if args.port:
        cfg["port"] = args.port
        config_changed = True
    if config_changed:
        _save_config(cfg)

    if _running():
        pid = PID.read_text().strip()
        print(f"MySQL is already running (PID {pid}) on port {cfg['port']}.")
        print(f"Socket: {SOCK}")
        return

    if not DATA.exists() or not any(DATA.iterdir()):
        rc = _initialize_data(cfg)
        if rc != 0:
            sys.exit(f"Data init failed (rc={rc}).")

    _start_daemon(cfg)

    for _ in range(60):
        if _running():
            break
        time.sleep(0.5)
    else:
        sys.exit(f"MySQL did not start within 30s. Check log: {LOG}")

    pid = PID.read_text().strip()
    print(f"MySQL started on port {cfg['port']} (PID {pid}).")
    print(f"Socket: {SOCK}")

    if args.password is not None:
        if _set_root_password(cfg, args.password):
            cfg["password"] = args.password
            _save_config(cfg)
            print("Root password updated and saved to config.")


if __name__ == "__main__":
    main()
