#!/usr/bin/env python3
"""mysql-up: start the standalone MySQL daemon."""

from __future__ import annotations

import argparse
import json
import os
import socket
import subprocess
import sys
import time
from pathlib import Path

IS_WIN = sys.platform == "win32"

ROOT = Path.home() / ".local" / "share" / "mac-fresh-setup" / "mysql"
CONFIG = ROOT / "config.json"
DATA = ROOT / "data"
RUNTIME = ROOT / "runtime"
PID = RUNTIME / "mysql.pid"
SOCK = RUNTIME / "mysql.sock"
LOG = RUNTIME / "mysql.log"


def _load_config() -> dict:
    if not CONFIG.exists():
        sys.exit(
            "MySQL is not installed. Run mac-fresh-setup → Databases → MySQL → Install."
        )
    return json.loads(CONFIG.read_text())


def _save_config(cfg: dict) -> None:
    CONFIG.write_text(json.dumps(cfg, indent=2))
    if not IS_WIN:
        CONFIG.chmod(0o600)


def _pid_alive(pid: int) -> bool:
    if IS_WIN:
        result = subprocess.run(
            ["tasklist", "/FI", f"PID eq {pid}", "/NH", "/FO", "CSV"],
            capture_output=True,
            text=True,
        )
        return result.returncode == 0 and str(pid) in result.stdout
    try:
        os.kill(pid, 0)
        return True
    except (ProcessLookupError, PermissionError):
        return False


def _port_free(port: int) -> bool:
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        try:
            s.bind(("127.0.0.1", port))
            return True
        except OSError:
            return False


def _running() -> bool:
    if not PID.exists():
        return False
    try:
        pid = int(PID.read_text().strip())
    except ValueError:
        return False
    return _pid_alive(pid)


def _bin(cfg: dict, name: str) -> Path:
    exe = f"{name}.exe" if IS_WIN else name
    return Path(cfg["install_dir"]) / "bin" / exe


def _initialize_data(cfg: dict) -> int:
    print(f"Initializing data dir at {DATA}...")
    DATA.mkdir(parents=True, exist_ok=True)
    cmd = [
        str(_bin(cfg, "mysqld")),
        "--initialize-insecure",
        f"--basedir={cfg['install_dir']}",
        f"--datadir={DATA}",
    ]
    if not IS_WIN:
        cmd.append(f"--user={os.environ.get('USER', 'mysql')}")
    result = subprocess.run(cmd)
    return result.returncode


def _start_daemon(cfg: dict) -> None:
    RUNTIME.mkdir(parents=True, exist_ok=True)
    if IS_WIN:
        cmd = [
            str(_bin(cfg, "mysqld")),
            "--standalone",
            f"--basedir={cfg['install_dir']}",
            f"--datadir={DATA}",
            f"--pid-file={PID}",
            f"--port={cfg['port']}",
            f"--log-error={LOG}",
        ]
        creationflags = (
            subprocess.CREATE_NEW_PROCESS_GROUP | subprocess.CREATE_NO_WINDOW
        )
        startupinfo = subprocess.STARTUPINFO()
        startupinfo.dwFlags |= subprocess.STARTF_USESHOWWINDOW
        startupinfo.wShowWindow = 0
        subprocess.Popen(
            cmd,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            stdin=subprocess.DEVNULL,
            creationflags=creationflags,
            startupinfo=startupinfo,
            close_fds=True,
        )
        return
    cmd = [
        str(_bin(cfg, "mysqld_safe")),
        f"--basedir={cfg['install_dir']}",
        f"--datadir={DATA}",
        f"--user={os.environ.get('USER', 'mysql')}",
        f"--socket={SOCK}",
        f"--pid-file={PID}",
        f"--port={cfg['port']}",
    ]
    with LOG.open("a") as log:
        subprocess.Popen(
            cmd,
            stdout=log,
            stderr=subprocess.STDOUT,
            start_new_session=True,
        )


def _admin_connect(cfg: dict) -> list[str]:
    cmd = [str(_bin(cfg, "mysqladmin")), "-uroot"]
    if IS_WIN:
        cmd.extend(["-h127.0.0.1", f"-P{cfg['port']}"])
    else:
        cmd.append(f"--socket={SOCK}")
    return cmd


def _set_root_password(cfg: dict, new_pass: str) -> bool:
    old_pass = cfg.get("password", "") or ""
    cmd = _admin_connect(cfg)
    if old_pass:
        cmd.append(f"-p{old_pass}")
    cmd.extend(["password", new_pass])
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        print(f"Could not set root password: {result.stderr.strip()}")
        return False
    return True


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="mysql-up",
        description="Start the standalone MySQL daemon (mac-fresh-setup).",
    )
    parser.add_argument(
        "-p", "--port", type=int,
        help="Port to listen on. Saved to config; reused by next mysql-up.",
    )
    parser.add_argument(
        "--pass", dest="password",
        help="Set/change the root password. Saved to config so mysql-cli works.",
    )
    args = parser.parse_args()

    cfg = _load_config()
    config_changed = False
    if args.port:
        cfg["port"] = args.port
        config_changed = True
    if config_changed:
        _save_config(cfg)

    if _running():
        pid = PID.read_text().strip()
        print(f"MySQL is already running (PID {pid}) on port {cfg['port']}.")
        if not IS_WIN:
            print(f"Socket: {SOCK}")
        return

    if not DATA.exists() or not any(DATA.iterdir()):
        rc = _initialize_data(cfg)
        if rc != 0:
            sys.exit(f"Data init failed (rc={rc}).")

    if not _port_free(cfg["port"]):
        sys.exit(
            f"Port {cfg['port']} is already in use. Another mysqld (system service?) "
            f"is bound. Either stop it, or pick a different port: "
            f"`mysql-up -p {cfg['port'] + 1}` (the choice is saved to config)."
        )

    _start_daemon(cfg)

    for _ in range(60):
        if _running():
            break
        time.sleep(0.5)
    else:
        sys.exit(f"MySQL did not start within 30s. Check log: {LOG}")

    pid = PID.read_text().strip()
    print(f"MySQL started on port {cfg['port']} (PID {pid}).")
    if IS_WIN:
        print(f"Host:   127.0.0.1:{cfg['port']}")
    else:
        print(f"Socket: {SOCK}")

    if args.password is not None:
        if _set_root_password(cfg, args.password):
            cfg["password"] = args.password
            _save_config(cfg)
            print("Root password updated and saved to config.")


if __name__ == "__main__":
    main()
